# ══════════════════════════════════════════════════════════════════════════════
# FISIOBALM — Template de Variáveis de Ambiente
# Copie para .env e preencha com suas credenciais reais.
# NUNCA commite o arquivo .env no Git.
# ══════════════════════════════════════════════════════════════════════════════

# ─── FIREBASE ────────────────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ─── APP ─────────────────────────────────────────────────────────────────────
VITE_APP_ID=fisiobalm-v1

# ─── ADMINS ───────────────────────────────────────────────────────────────────
# Formato JSON — CPF sem pontuação
VITE_ADMINS=[{"cpf":"00000000000","name":"Nome Admin","role":"admin"}]

# ─── PROFISSIONAIS POR TURNO ─────────────────────────────────────────────────
VITE_PROF_MANHA=Nome da Fisioterapeuta da Manhã
VITE_PROF_TARDE=Nome da Fisioterapeuta da Tarde